# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# LLM Provider Keys (uncomment whichever you use)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Model selection
OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-opus-4-6

# Agent settings
MAX_ITERATIONS=10
TEMPERATURE=0.0

# Optional: LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=assignment-1
