# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM Provider Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Model Selection ────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-opus-4-6
EMBEDDING_BACKEND=sentence-transformers   # or "openai"
EMBEDDING_MODEL=all-MiniLM-L6-v2          # HuggingFace model ID or OpenAI model

# ── Vector Store ───────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./.chroma_db
# CHROMA_HOST=localhost    # uncomment if using ChromaDB as a server
# CHROMA_PORT=8000

# ── Retrieval Settings ─────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.0
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Agent Settings ─────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
TEMPERATURE=0.0

# ── Evaluation ─────────────────────────────────────────────────────────────
EVAL_DATASET_PATH=./data/eval.jsonl
EVAL_OUTPUT_PATH=./results/eval_results.json

# ── Observability (optional) ───────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=assignment-2
